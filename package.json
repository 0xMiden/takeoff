{
  "name": "miden-takeoff",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/src/server.ts",
    "dev:all": "concurrently \"yarn dev\" \"yarn dev:server\"",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "cf:deploy": "yarn build && wrangler deploy",
    "cf:dev": "wrangler dev"
  },
  "dependencies": {
    "@miden-sdk/miden-sdk": "^0.14.8",
    "@miden-sdk/miden-wallet-adapter-base": "^0.14.3",
    "@miden-sdk/miden-wallet-adapter-react": "^0.14.3",
    "@miden-sdk/react": "^0.14.8",
    "@monaco-editor/react": "^4.6.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@types/lodash": "^4.17.24",
    "allotment": "^1.0.9",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "dotenv": "^17.4.0",
    "es-module-lexer": "^2.1.0",
    "lodash": "^4.18.1",
    "lucide-react": "^1.14.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.0",
    "sucrase": "^3.35.0",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@miden-sdk/vite-plugin": "^0.14.8",
    "@tailwindcss/typography": "^0.5.0",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.0.0",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "wrangler": "^4.90.0"
  }
}
